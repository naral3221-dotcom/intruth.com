# ===========================================
# DATABASE
# ===========================================
# 로컬 개발 (SQLite)
# DATABASE_URL="file:./dev.db"

# 프로덕션 (PostgreSQL) - Railway 자동 생성
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# ===========================================
# JWT 인증
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# SERVER
# ===========================================
PORT=3001
NODE_ENV=development

# OpenAI AI features
# Used by meeting recording transcription and later agentic workflows.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_PROMPT=INTRUTH 교회 리더 회의 녹음입니다. 한국어 회의 내용을 자연스럽게 전사하고, 교회 사역 용어와 이름을 가능한 정확히 보존하세요.
OPENAI_ASSISTANT_MODEL=gpt-4o-mini
OPENAI_AGENT_MODEL=gpt-4o-mini
OPENAI_MEETING_MODEL=gpt-4o-mini
# Optional: in_memory | 24h. Leave empty to use the model default.
OPENAI_PROMPT_CACHE_RETENTION=
# Optional local-first LLM provider for LM Studio, OpenClaw, or any OpenAI-compatible /v1 endpoint.
# When enabled, assistant/agent/meeting-material text generation tries the local endpoint first.
# If the local call fails or structured JSON is invalid, INTRUTH falls back to OpenAI when OPENAI_API_KEY exists.
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_API_KEY=lm-studio
LOCAL_LLM_MODEL=qwen3.6-27b
LOCAL_LLM_ASSISTANT_MODEL=
LOCAL_LLM_AGENT_MODEL=
LOCAL_LLM_MEETING_MODEL=
LOCAL_LLM_TIMEOUT_MS=45000
LOCAL_LLM_PROBE_TIMEOUT_MS=2500
LOCAL_LLM_REASONING_EFFORT=none
LOCAL_LLM_MAX_OUTPUT_TOKENS=1800
LOCAL_LLM_FALLBACK_TO_OPENAI=true
LOCAL_LLM_USE_FOR_ASSISTANT=true
LOCAL_LLM_USE_FOR_AGENT=true
LOCAL_LLM_USE_FOR_MEETING=true
# Optional cost estimation rates per 1M tokens.
OPENAI_ASSISTANT_INPUT_COST_PER_1M=
OPENAI_ASSISTANT_CACHED_INPUT_COST_PER_1M=
OPENAI_ASSISTANT_OUTPUT_COST_PER_1M=

# ===========================================
# OneDrive (파일 스토리지) - 선택사항
# ===========================================
# Azure Portal에서 앱 등록 후 발급받은 값 입력
# 설정 방법: docs/ONEDRIVE_SETUP.md 참조
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=http://localhost:3001/api/onedrive/callback
ONEDRIVE_FOLDER_PATH=/워크플로우/첨부파일

# ===========================================
# Gnuboard DB (읽기 전용 - 회원 인증용) - 선택사항
# ===========================================
GNUBOARD_DB_HOST=localhost
GNUBOARD_DB_USER=username
GNUBOARD_DB_PASSWORD=password
GNUBOARD_DB_NAME=gnuboard_db
