# ===========================================
# DATABASE
# ===========================================
# 로컬 개발 (SQLite)
# DATABASE_URL="file:./dev.db"

# 프로덕션 (PostgreSQL) - Railway 자동 생성
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# ===========================================
# JWT 인증
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# SERVER
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# OneDrive (파일 스토리지) - 선택사항
# ===========================================
# Azure Portal에서 앱 등록 후 발급받은 값 입력
# 설정 방법: docs/ONEDRIVE_SETUP.md 참조
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=http://localhost:3001/api/onedrive/callback
ONEDRIVE_FOLDER_PATH=/워크플로우/첨부파일

# ===========================================
# Gnuboard DB (읽기 전용 - 회원 인증용) - 선택사항
# ===========================================
GNUBOARD_DB_HOST=localhost
GNUBOARD_DB_USER=username
GNUBOARD_DB_PASSWORD=password
GNUBOARD_DB_NAME=gnuboard_db
