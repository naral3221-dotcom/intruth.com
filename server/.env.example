# ===========================================
# DATABASE
# ===========================================
# 로컬 개발 (SQLite)
# DATABASE_URL="file:./dev.db"

# 프로덕션 (PostgreSQL) - Railway 자동 생성
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# ===========================================
# JWT 인증
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# SERVER
# ===========================================
PORT=3001
NODE_ENV=development

# OpenAI AI features
# Used by meeting recording transcription and later agentic workflows.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_PROMPT=INTRUTH 교회 리더 회의 녹음입니다. 한국어 회의 내용을 자연스럽게 전사하고, 교회 사역 용어와 이름을 가능한 정확히 보존하세요.
OPENAI_ASSISTANT_MODEL=gpt-4o-mini
OPENAI_MEETING_MODEL=gpt-4o-mini
# Optional: in_memory | 24h. Leave empty to use the model default.
OPENAI_PROMPT_CACHE_RETENTION=
# Optional cost estimation rates per 1M tokens.
OPENAI_ASSISTANT_INPUT_COST_PER_1M=
OPENAI_ASSISTANT_CACHED_INPUT_COST_PER_1M=
OPENAI_ASSISTANT_OUTPUT_COST_PER_1M=

# ===========================================
# OneDrive (파일 스토리지) - 선택사항
# ===========================================
# Azure Portal에서 앱 등록 후 발급받은 값 입력
# 설정 방법: docs/ONEDRIVE_SETUP.md 참조
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=http://localhost:3001/api/onedrive/callback
ONEDRIVE_FOLDER_PATH=/워크플로우/첨부파일

# ===========================================
# Gnuboard DB (읽기 전용 - 회원 인증용) - 선택사항
# ===========================================
GNUBOARD_DB_HOST=localhost
GNUBOARD_DB_USER=username
GNUBOARD_DB_PASSWORD=password
GNUBOARD_DB_NAME=gnuboard_db
