generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String // JSON 문자열로 저장
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  members     Member[]

  @@map("roles")
}

model Member {
  id                 String   @id @default(uuid())
  gnuboardId         String?  @unique @map("gnuboard_id")
  username           String?  @unique
  email              String   @unique
  password           String?
  name               String
  avatarUrl          String?  @map("avatar_url")
  roleId             String   @map("role_id")
  department         String?
  position           String?
  isActive           Boolean  @default(true) @map("is_active")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  role                 Role                    @relation(fields: [roleId], references: [id])
  ownedProjects        Project[]               @relation("ProjectOwner")
  projectMemberships   ProjectMember[]
  ledTeams             Team[]                  @relation("TeamLeader")
  teamMemberships      TeamMember[]
  assignedTasks        Task[]                  @relation("TaskAssignee")
  reportedTasks        Task[]                  @relation("TaskReporter")
  comments             Comment[]
  activityLogs         ActivityLog[]
  assistantRuns        AiAssistantRun[]
  commandMessages      AiCommandMessage[]
  assistantMemories    AiAssistantMemory[]
  agentActions         AiAgentAction[]         @relation("AiAgentActionOwner")
  reviewedAgentActions AiAgentAction[]         @relation("AiAgentActionReviewer")
  createdRoutineTasks  RoutineTask[]           @relation("RoutineTaskCreator")
  routineAssignments   RoutineTaskAssignee[]
  routineCompletions   RoutineTaskCompletion[]

  // Cell 관련 관계
  ledCells           Cell[]       @relation("CellLeader")
  cellMemberships    CellMember[]
  attendances        Attendance[] @relation("AttendanceMember")
  checkedAttendances Attendance[] @relation("AttendanceChecker")

  @@map("members")
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  status      String    @default("ACTIVE") // ACTIVE, COMPLETED, ARCHIVED
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  ownerId     String    @map("owner_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner        Member          @relation("ProjectOwner", fields: [ownerId], references: [id])
  members      ProjectMember[]
  tasks        Task[]
  labels       TaskLabel[]
  routineTasks RoutineTask[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  memberId  String   @map("member_id")
  role      String   @default("VIEWER") // OWNER, EDITOR, VIEWER
  joinedAt  DateTime @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([projectId, memberId])
  @@map("project_members")
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String   @default("#06b6d4")
  leaderId    String?  @map("leader_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  leader   Member?      @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members  TeamMember[]
  meetings Meeting[]

  @@index([leaderId])
  @@map("wf_teams")
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String   @map("team_id")
  memberId String   @map("member_id")
  role     String   @default("MEMBER") // LEADER, MEMBER
  joinedAt DateTime @default(now()) @map("joined_at")

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([teamId, memberId])
  @@index([memberId])
  @@map("wf_team_members")
}

model Task {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  title          String
  description    String?
  status         String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  priority       String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assigneeId     String?   @map("assignee_id")
  reporterId     String?   @map("reporter_id")
  startDate      DateTime? @map("start_date")
  dueDate        DateTime? @map("due_date")
  estimatedHours Float?    @map("estimated_hours")
  actualHours    Float?    @map("actual_hours")
  order          Int       @default(0)
  parentId       String?   @map("parent_id")
  folderUrl      String?   @map("folder_url")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee          Member?             @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter          Member?             @relation("TaskReporter", fields: [reporterId], references: [id])
  parent            Task?               @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks          Task[]              @relation("TaskSubtasks")
  labels            TaskLabelRelation[]
  comments          Comment[]
  activityLogs      ActivityLog[]
  meetingActionItem MeetingActionItem?

  @@map("tasks")
}

model TaskLabel {
  id        String @id @default(uuid())
  name      String
  color     String
  projectId String @map("project_id")

  project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskLabelRelation[]

  @@map("task_labels")
}

model TaskLabelRelation {
  taskId  String @map("task_id")
  labelId String @map("label_id")

  task  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_label_relations")
}

model Comment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  authorId  String   @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author Member @relation(fields: [authorId], references: [id])

  @@map("comments")
}

model ActivityLog {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  memberId  String   @map("member_id")
  action    String
  details   String? // JSON 문자열로 저장
  createdAt DateTime @default(now()) @map("created_at")

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id])

  @@map("activity_logs")
}

model RoutineTask {
  id               String   @id @default(uuid())
  title            String
  description      String?
  repeatType       String   @default("weekly") @map("repeat_type") // daily, weekly, custom
  repeatDays       Int[]    @map("repeat_days")
  projectId        String?  @map("project_id")
  priority         String   @default("MEDIUM")
  estimatedMinutes Int?     @map("estimated_minutes")
  isActive         Boolean  @default(true) @map("is_active")
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project     Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy   Member                  @relation("RoutineTaskCreator", fields: [createdById], references: [id])
  assignees   RoutineTaskAssignee[]
  completions RoutineTaskCompletion[]

  @@index([projectId])
  @@index([createdById])
  @@index([isActive])
  @@map("wf_routine_tasks")
}

model RoutineTaskAssignee {
  id            String   @id @default(uuid())
  routineTaskId String   @map("routine_task_id")
  memberId      String   @map("member_id")
  assignedAt    DateTime @default(now()) @map("assigned_at")

  routineTask RoutineTask @relation(fields: [routineTaskId], references: [id], onDelete: Cascade)
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([routineTaskId, memberId])
  @@index([memberId])
  @@map("wf_routine_task_assignees")
}

model RoutineTaskCompletion {
  id            String   @id @default(uuid())
  routineTaskId String   @map("routine_task_id")
  date          String
  completedById String   @map("completed_by_id")
  completedAt   DateTime @default(now()) @map("completed_at")

  routineTask RoutineTask @relation(fields: [routineTaskId], references: [id], onDelete: Cascade)
  completedBy Member      @relation(fields: [completedById], references: [id])

  @@unique([routineTaskId, date])
  @@index([completedById])
  @@map("wf_routine_task_completions")
}

// ==================== 회의자료 게시판 모델 ====================

model Meeting {
  id          Int      @id @default(autoincrement())
  title       String
  meetingDate DateTime @map("meeting_date")
  location    String?
  projectId   String?  @map("project_id")
  teamId      String?  @map("team_id")
  content     String
  contentType String   @default("text") @map("content_type") // text, json (TipTap)
  summary     String?
  authorId    String   @map("author_id")
  status      String   @default("DRAFT") // DRAFT, PUBLISHED
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  attendees      MeetingAttendee[]
  attachments    MeetingAttachment[]
  comments       MeetingComment[]
  agendas        MeetingAgenda[]
  actionItems    MeetingActionItem[]
  recordings     MeetingRecording[]
  materialDrafts MeetingMaterialDraft[]
  team           Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@map("wf_meetings")
}

model MeetingAttendee {
  id        Int      @id @default(autoincrement())
  meetingId Int      @map("meeting_id")
  memberId  String   @map("member_id")
  createdAt DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, memberId])
  @@map("wf_meeting_attendees")
}

model MeetingAttachment {
  id          Int      @id @default(autoincrement())
  meetingId   Int      @map("meeting_id")
  fileName    String   @map("file_name")
  storedName  String   @map("stored_name")
  filePath    String   @map("file_path")
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")
  oneDriveId  String?  @map("onedrive_id")
  storageType String   @default("local") @map("storage_type")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("wf_meeting_attachments")
}

model MeetingComment {
  id        Int      @id @default(autoincrement())
  meetingId Int      @map("meeting_id")
  authorId  String   @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("wf_meeting_comments")
}

model MeetingAgenda {
  id          Int      @id @default(autoincrement())
  meetingId   Int      @map("meeting_id")
  order       Int      @default(0)
  title       String
  description String?
  duration    Int? // 예상 소요 시간 (분)
  presenter   String? // 발표자/담당자 이름
  status      String   @default("PENDING") // PENDING, DISCUSSED, SKIPPED
  createdAt   DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("wf_meeting_agendas")
}

model MeetingActionItem {
  id          Int       @id @default(autoincrement())
  meetingId   Int       @map("meeting_id")
  title       String
  description String?
  assigneeId  String?   @map("assignee_id")
  dueDate     DateTime? @map("due_date")
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String    @default("TODO") // TODO, IN_PROGRESS, DONE
  taskId      String?   @unique @map("task_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@map("wf_meeting_action_items")
}

model MeetingRecording {
  id              Int      @id @default(autoincrement())
  meetingId       Int      @map("meeting_id")
  fileName        String   @map("file_name")
  storedName      String   @map("stored_name")
  filePath        String   @map("file_path")
  fileSize        Int      @map("file_size")
  mimeType        String   @map("mime_type")
  durationSeconds Int?     @map("duration_seconds")
  status          String   @default("UPLOADED") // UPLOADED, TRANSCRIBING, TRANSCRIBED, FAILED
  transcriptText  String?  @map("transcript_text")
  errorMessage    String?  @map("error_message")
  oneDriveId      String?  @map("onedrive_id")
  storageType     String   @default("local") @map("storage_type")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  meeting  Meeting                    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  segments MeetingTranscriptSegment[]

  @@index([meetingId])
  @@index([createdById])
  @@map("wf_meeting_recordings")
}

model MeetingTranscriptSegment {
  id           Int     @id @default(autoincrement())
  recordingId  Int     @map("recording_id")
  order        Int     @default(0)
  speaker      String?
  startSeconds Float?  @map("start_seconds")
  endSeconds   Float?  @map("end_seconds")
  text         String
  confidence   Float?

  recording MeetingRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@index([recordingId])
  @@map("wf_meeting_transcript_segments")
}

model MeetingMaterialDraft {
  id                   Int       @id @default(autoincrement())
  meetingId            Int       @map("meeting_id")
  recordingId          Int?      @map("recording_id")
  materials            Json
  transcriptSnippet    String?   @map("transcript_snippet")
  sourceRecordingCount Int       @default(0) @map("source_recording_count")
  status               String    @default("DRAFT") // DRAFT, APPLIED, DISCARDED
  createdById          String    @map("created_by_id")
  appliedById          String?   @map("applied_by_id")
  appliedAt            DateTime? @map("applied_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, status])
  @@index([createdById])
  @@map("wf_meeting_material_drafts")
}

model AiAssistantRun {
  id                 Int      @id @default(autoincrement())
  memberId           String   @map("member_id")
  prompt             String
  scopeType          String   @default("GLOBAL") @map("scope_type")
  scopeId            String?  @map("scope_id")
  scopeLabel         String?  @map("scope_label")
  answer             String
  highlights         Json
  suggestedQuestions Json     @map("suggested_questions")
  kakaoBrief         String   @map("kakao_brief")
  sourceCounts       Json     @map("source_counts")
  mode               String
  model              String?
  inputTokens        Int?     @map("input_tokens")
  outputTokens       Int?     @map("output_tokens")
  totalTokens        Int?     @map("total_tokens")
  cachedTokens       Int?     @map("cached_tokens")
  reasoningTokens    Int?     @map("reasoning_tokens")
  estimatedCostUsd   Float?   @map("estimated_cost_usd")
  status             String   @default("COMPLETED") // COMPLETED, FAILED
  errorMessage       String?  @map("error_message")
  createdAt          DateTime @default(now()) @map("created_at")

  member       Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  agentActions AiAgentAction[]

  @@index([memberId, createdAt])
  @@map("wf_ai_assistant_runs")
}

model AiCommandMessage {
  id        Int      @id @default(autoincrement())
  memberId  String   @map("member_id")
  role      String
  content   String
  route     String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
  @@map("wf_ai_command_messages")
}

model AiAssistantMemory {
  id        Int      @id @default(autoincrement())
  memberId  String   @map("member_id")
  scopeKey  String   @map("scope_key")
  scopeType String   @default("GLOBAL") @map("scope_type")
  scopeId   String?  @map("scope_id")
  summary   String   @default("")
  facts     Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, scopeKey])
  @@index([memberId, updatedAt])
  @@map("wf_ai_assistant_memories")
}

model AiAgentAction {
  id             Int       @id @default(autoincrement())
  assistantRunId Int?      @map("assistant_run_id")
  memberId       String    @map("member_id")
  actionType     String    @map("action_type")
  status         String    @default("PENDING_APPROVAL")
  scopeType      String    @default("GLOBAL") @map("scope_type")
  scopeId        String?   @map("scope_id")
  scopeLabel     String?   @map("scope_label")
  preview        Json
  result         Json?
  errorMessage   String?   @map("error_message")
  reviewedById   String?   @map("reviewed_by_id")
  reviewedAt     DateTime? @map("reviewed_at")
  executedAt     DateTime? @map("executed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  assistantRun AiAssistantRun? @relation(fields: [assistantRunId], references: [id], onDelete: SetNull)
  member       Member          @relation("AiAgentActionOwner", fields: [memberId], references: [id], onDelete: Cascade)
  reviewedBy   Member?         @relation("AiAgentActionReviewer", fields: [reviewedById], references: [id])

  @@index([memberId, status, createdAt])
  @@index([assistantRunId])
  @@map("wf_ai_agent_actions")
}

// ==================== 셀 그룹 출석 관리 모델 ====================

model Cell {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String   @default("#00bcd4")
  leaderId    String   @map("leader_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  leader      Member       @relation("CellLeader", fields: [leaderId], references: [id])
  members     CellMember[]
  attendances Attendance[]

  @@map("cells")
}

model CellMember {
  id       String    @id @default(uuid())
  cellId   String    @map("cell_id")
  memberId String    @map("member_id")
  role     String    @default("MEMBER") // LEADER, SUB_LEADER, MEMBER
  joinedAt DateTime  @default(now()) @map("joined_at")
  leftAt   DateTime? @map("left_at")
  isActive Boolean   @default(true) @map("is_active")

  cell   Cell   @relation(fields: [cellId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([cellId, memberId])
  @@map("cell_members")
}

model Attendance {
  id          String   @id @default(uuid())
  cellId      String   @map("cell_id")
  memberId    String   @map("member_id")
  attendDate  DateTime @map("attend_date")
  meetingType String   @map("meeting_type") // SUNDAY_SERVICE, CELL_MEETING
  status      String   @default("PRESENT") // PRESENT, ABSENT, LATE, EXCUSED, ONLINE
  note        String?
  checkedById String   @map("checked_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cell      Cell   @relation(fields: [cellId], references: [id], onDelete: Cascade)
  member    Member @relation("AttendanceMember", fields: [memberId], references: [id])
  checkedBy Member @relation("AttendanceChecker", fields: [checkedById], references: [id])

  @@unique([cellId, memberId, attendDate, meetingType])
  @@map("attendances")
}
