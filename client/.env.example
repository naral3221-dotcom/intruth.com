# Copy this file to .env.local and configure for your environment

# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api

# Mock Mode (set to 'false' to use real backend)
VITE_USE_MOCK=true

# Logging Level (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# Kakao Developers JavaScript key (optional, enables Kakao Talk Share SDK)
VITE_KAKAO_JAVASCRIPT_KEY=

# Public URL used inside Kakao/shared links after VPS/domain deployment
# Example: https://intruth.com
VITE_PUBLIC_APP_URL=
